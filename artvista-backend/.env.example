# Backend environment variables (copy to .env, do NOT commit .env)

# Mongo
MONGO_URI=mongodb://localhost:27017/artvista

# Server
PORT=5000

# Chat provider: 'ollama' (free local), 'openai' (paid key), or 'auto'
AI_CHAT_PROVIDER=ollama

# ArtVista Virtual Professor (OpenAI-compatible)
# Required for real AI responses:
OPENAI_API_KEY=your_api_key_here

# Optional
OPENAI_MODEL=gpt-4o-mini
# If using a compatible provider (or a gateway), set the full chat completions endpoint:
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Optional: Free local AI using Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional: Real-time web search (for "latest/today/news/price..." questions)
# Create an API key at Tavily, then set:
TAVILY_API_KEY=your_tavily_api_key_here
# How many web sources to attach (1-10)
TAVILY_MAX_RESULTS=5

